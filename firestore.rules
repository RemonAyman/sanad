rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).exists()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.sender in ["child", "ai"];
      allow create: if isAdmin();
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /talents/{talentId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.title is string
        && request.resource.data.type in ["drawing", "story", "video"]
        && request.resource.data.contentUrl is string
        && request.resource.data.storyText is string
        && request.resource.data.approved == false
        && request.resource.data.createdAt is timestamp;
      allow read: if request.auth != null || resource.data.approved == true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
